# AutoFyn Sandbox — gVisor backend (no KVM required)
# Works on macOS (Apple Silicon), Linux, and CI environments.
#
# Versions pinned in build.sh (source of truth).
# Defaults here are fallbacks for standalone docker build.

ARG PYTHON_VERSION=3.12
ARG GVISOR_VERSION=20260323.0

FROM python:${PYTHON_VERSION}-slim

ENV DEBIAN_FRONTEND=noninteractive
ARG GVISOR_VERSION

# System deps (curl for healthcheck)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install gVisor (runsc) — pinned version, auto-detect architecture
RUN ARCH=$(uname -m) && \
    curl -fsSL "https://storage.googleapis.com/gvisor/releases/release/${GVISOR_VERSION}/${ARCH}/runsc" \
    -o /usr/local/bin/runsc && \
    chmod +x /usr/local/bin/runsc

RUN mkdir -p /opt/autofyn

COPY sandbox/pyproject.toml /opt/autofyn/
RUN pip install --no-cache-dir /opt/autofyn/

COPY sandbox/base.py /opt/autofyn/
COPY sandbox/gvisor.py /opt/autofyn/
COPY sandbox/firecracker/ /opt/autofyn/firecracker/
COPY sandbox/manager.py /opt/autofyn/
COPY config/ /opt/autofyn/config/

WORKDIR /opt/autofyn

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s \
    CMD curl -f http://localhost:8080/health || exit 1

ENTRYPOINT ["python3", "manager.py"]
