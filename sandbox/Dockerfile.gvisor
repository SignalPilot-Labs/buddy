# AutoFyn Sandbox — execution environment (gVisor backend, no KVM required)
#
# All code execution happens here: git, npm, Claude SDK sessions.
# The agent container sends commands via HTTP; this container executes them.
#
# Versions pinned in build.sh (source of truth).
# Defaults here are fallbacks for standalone docker build.

ARG PYTHON_VERSION=3.12
ARG NODE_VERSION=22
ARG GVISOR_VERSION=20260323.0
ARG UV_VERSION=0.11

FROM docker.io/astral/uv:${UV_VERSION} AS uv
FROM python:${PYTHON_VERSION}-slim

# uv for fast Python installs
COPY --from=uv /uv /usr/local/bin/uv

ENV DEBIAN_FRONTEND=noninteractive
ARG GVISOR_VERSION
ARG NODE_VERSION

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    jq \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install gVisor (runsc) — pinned version, auto-detect architecture
RUN ARCH=$(uname -m) && \
    curl -fsSL "https://storage.googleapis.com/gvisor/releases/release/${GVISOR_VERSION}/${ARCH}/runsc" \
    -o /usr/local/bin/runsc && \
    chmod +x /usr/local/bin/runsc

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (required for Claude Code CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Frontend dev tools
RUN npm install -g \
    typescript \
    eslint \
    prettier

# Docker CLI (inert without socket mount — enabled via --allow-docker at start)
RUN curl -fsSL https://download.docker.com/linux/debian/gpg \
    | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
    > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y --no-install-recommends docker-ce-cli \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/autofyn

# Create non-root user BEFORE copying app files (avoids slow chown -R)
RUN useradd -m agentuser \
    && mkdir -p /home/agentuser/.claude /home/agentuser/repo \
    && echo '{}' > /home/agentuser/.claude.json \
    && chown agentuser:agentuser /home/agentuser/.claude /home/agentuser/repo /home/agentuser/.claude.json

# Config (for sandbox config loading)
COPY --chown=agentuser:agentuser config/ /opt/autofyn/config/

# Sandbox packages — deps first for layer caching
COPY --chown=agentuser:agentuser sandbox/pyproject.toml /opt/autofyn/
# Runtime + dev tools (pytest, pyright, ruff, etc. for builder/reviewer)
RUN uv pip install --system --no-cache "/opt/autofyn/[dev]"

# Source code (changes here don't bust dep install cache)
COPY --chown=agentuser:agentuser sandbox/ /opt/autofyn/

# Shared DB package — deps first for layer caching
COPY --chown=agentuser:agentuser db/pyproject.toml /opt/autofyn/db/pyproject.toml
COPY --chown=agentuser:agentuser db/__init__.py /opt/autofyn/db/__init__.py
RUN uv pip install --system --no-cache /opt/autofyn/db/
COPY --chown=agentuser:agentuser db/ /opt/autofyn/db/

# Skills — under /opt/autofyn/.claude/skills/ (discovered via add_dirs, not ~/.claude volume)
COPY --chown=agentuser:agentuser autofyn/skills/ /opt/autofyn/.claude/skills/

RUN chown agentuser:agentuser /opt/autofyn

USER agentuser

# Git config
RUN git config --global user.name "AutoFyn Bot" \
    && git config --global user.email "autofyn-bot@noreply.github.com" \
    && git config --global --add safe.directory '*'

WORKDIR /opt/autofyn

EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s \
    CMD curl -f http://localhost:8080/health || exit 1

ENTRYPOINT ["python3", "server.py"]
