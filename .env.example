# -----------------------------------------------------------------------
# Buddy — environment variable reference
# -----------------------------------------------------------------------
# These variables are read by install.sh (skips the interactive credential
# prompt) and can be set before running buddy start or buddy update.
#
# See config/config.yml for all config.yml options these override.
# -----------------------------------------------------------------------

# Required credentials (passed to buddy settings set during install)
ANTHROPIC_API_KEY=sk-ant-...          # Anthropic API key (required)
GITHUB_TOKEN=ghp_...                  # GitHub personal access token (required)
GITHUB_REPO=owner/repo                # Default target repository (required)

# Database — override the default password (default: buddy, fine for local dev)
DB_PASSWORD=buddy

# Sandbox resource limits (override config.yml sandbox section)
SP_MAX_VMS=10                         # Max concurrent sandbox VMs
SP_VM_MEMORY_MB=512                   # Memory per VM in megabytes
SP_VM_VCPUS=1                         # vCPUs allocated per VM
SP_VM_TIMEOUT_SEC=300                 # Max VM runtime in seconds
SP_LOG_LEVEL=info                     # Sandbox log level: debug | info | warn | error
