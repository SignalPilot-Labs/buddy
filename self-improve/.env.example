# Required: Claude Code OAuth token (authenticates the CLI inside Docker)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Required: GitHub PAT with repo scope (used by gh CLI, never exposed to LLM)
GIT_TOKEN=ghp_...

# Required: GitHub repo slug (owner/repo) - agent is GATED to only this repo
GITHUB_REPO=your-org/SignalPilot

# Optional: Max budget per run in USD (default: 50)
MAX_BUDGET_USD=50

# Custom prompts are injected via the monitor UI at http://localhost:3400
# Use the "Inject Prompt" button to redirect the agent's focus mid-run

# Optional: Benchmark data directory on host (default: D:\signalpilot-bench)
# This is mounted into the container at /bench
# SP_BENCHMARK_DIR=D:\signalpilot-bench

# --- Internal (set by docker-compose, do not override) ---
# AUDIT_DB_URL=postgresql://improve_admin:Impr0ve!Aud1t@postgres:5432/improve_audit
