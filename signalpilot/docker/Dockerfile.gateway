FROM python:3.12-slim

WORKDIR /app

# Copy source first so pip can find the package
COPY pyproject.toml .
COPY gateway/ gateway/

# Install core dependencies + commonly used optional connectors
RUN pip install --no-cache-dir -e . && \
    pip install --no-cache-dir duckdb clickhouse-driver clickhouse-connect sshtunnel cryptography

EXPOSE 3300
CMD ["uvicorn", "gateway.main:app", "--host", "0.0.0.0", "--port", "3300"]
