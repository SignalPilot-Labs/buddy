# AutoFyn Agent — decision-making brain (no code execution)
#
# All code execution (git, npm, Claude SDK) happens in the sandbox container.
# This container only runs the orchestrator: FastAPI + httpx → sandbox HTTP.
#
# Versions pinned in build.sh (source of truth).
ARG PYTHON_VERSION=3.12

FROM python:${PYTHON_VERSION}-slim

# System dependencies (curl for healthcheck, gosu for non-root)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gosu \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Config (required by db/connection.py and config loader)
COPY config/ /app/config/

# Shared DB package (models + connection pool)
COPY db/pyproject.toml /app/db/pyproject.toml
COPY db/__init__.py /app/db/__init__.py
RUN pip install --no-cache-dir /app/db/
COPY db/ /app/db/

# AutoFyn agent packages
COPY autofyn/pyproject.toml /app/pyproject.toml
RUN pip install --no-cache-dir "/app/[dev]"
COPY autofyn/core/ /app/core/
COPY autofyn/tools/ /app/tools/
COPY autofyn/utils/ /app/utils/
COPY autofyn/sandbox_manager/ /app/sandbox_manager/
COPY autofyn/prompts/ /app/prompts/
COPY autofyn/skills/ /app/skills/
COPY autofyn/endpoints.py /app/endpoints.py
COPY autofyn/server.py /app/server.py

# Run as non-root
RUN useradd -m agentuser \
    && chown -R agentuser:agentuser /app

USER agentuser

ENV PYTHONPATH="/app"

# Entrypoint
COPY --chown=root:root autofyn/entrypoint.sh /app/entrypoint.sh

USER root
RUN chmod +x /app/entrypoint.sh
ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["python", "-m", "server"]
