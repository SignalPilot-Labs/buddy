# AutoFyn Agent — decision-making brain (no code execution)
#
# All code execution (git, npm, Claude SDK) happens in the sandbox container.
# This container only runs the orchestrator: FastAPI + httpx → sandbox HTTP.
#
# Versions pinned in build.sh (source of truth).
ARG PYTHON_VERSION=3.12
ARG UV_VERSION=0.11

FROM docker.io/astral/uv:${UV_VERSION} AS uv
FROM python:${PYTHON_VERSION}-slim

# uv for fast Python installs
COPY --from=uv /uv /usr/local/bin/uv

# System dependencies (curl for healthcheck, gosu for non-root)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gosu \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Create non-root user BEFORE copying app files (avoids slow chown -R)
RUN useradd -m agentuser && chown agentuser:agentuser /app

# Config (required by db/connection.py and config loader)
COPY --chown=agentuser:agentuser config/ /app/config/

# Shared DB package (models + connection pool) — deps first for layer caching
COPY --chown=agentuser:agentuser db/pyproject.toml /app/db/pyproject.toml
COPY --chown=agentuser:agentuser db/__init__.py /app/db/__init__.py
RUN uv pip install --system --no-cache /app/db/
COPY --chown=agentuser:agentuser db/ /app/db/

# AutoFyn agent packages — deps first for layer caching
COPY --chown=agentuser:agentuser autofyn/pyproject.toml /app/pyproject.toml
RUN uv pip install --system --no-cache "/app/[dev]"

# Source code (changes here don't bust dep install cache)
COPY --chown=agentuser:agentuser autofyn/core/ /app/core/
COPY --chown=agentuser:agentuser autofyn/tools/ /app/tools/
COPY --chown=agentuser:agentuser autofyn/utils/ /app/utils/
COPY --chown=agentuser:agentuser autofyn/sandbox_manager/ /app/sandbox_manager/
COPY --chown=agentuser:agentuser autofyn/prompts/ /app/prompts/
COPY --chown=agentuser:agentuser autofyn/endpoints.py /app/endpoints.py
COPY --chown=agentuser:agentuser autofyn/server.py /app/server.py

# Entrypoint
COPY --chown=root:root autofyn/entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENV PYTHONPATH="/app"

# Entrypoint runs as root (chmod docker socket, gosu to agentuser)
ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["python", "-m", "server"]
